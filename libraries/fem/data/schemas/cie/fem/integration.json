{
    "$id" : "/cie/fem/integration",
    "type" : "object",
    "description" : "Settings related to performing numerical quadrature.",
    "allOf" : [
        {"$ref" : "/cie/fem/integrand-processor"},
        {
            "oneOf" : [
                {"$ref" : "/cie/fem/gauss-legendre-quadrature"},
                {"$ref" : "/cie/fem/kd-tree-quadrature"}
            ]
        }
    ],
    "default" : {
        "type" : "kd-tree-quadrature",
        "template" : {
            "type" : "gauss-legendre-quadrature",
            "order" : 3
        },
        "min-tree-depth" : 0,
        "max-tree-depth" : 6,
        "min-domain-norm" : 1e-6,
        "batch-size" : 1e4,
        "device" : "host"
    }
}
